{
  "manifest_version": 2,
  "name": "Calendar Picker",
  "version": "1.0",
  "description": "Picker daty i godziny w bocznym panelu",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "sidebar_action": {
    "default_title": "Calendar Picker",
    "default_panel": "sidebar.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "permissions": [
    "clipboardWrite",
    "storage"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "calendar-picker@local",
      "strict_min_version": "109.0"
    }
  }
}
